# Local environment variables for development only.
# Do not commit real secrets.

FLASK_DEBUG=true

# Local LLM settings (Ollama + Qwen, no API key required)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# Local embedding model (no OpenAI key required)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# RAG tuning
TOP_K=3
CHUNK_SIZE=1000
CHUNK_OVERLAP=100

VECTORSTORE_DIR=storage/vectorstore
CHAT_HISTORY_DIR=storage/conversations
